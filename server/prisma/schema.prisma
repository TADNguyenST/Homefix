generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  TECHNICIAN
  ADMIN
}

model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique @db.VarChar(255)
  password_hash String    @db.VarChar(255)
  role          Role
  full_name     String    @db.VarChar(100)
  phone         String?   @db.VarChar(15)
  avatar_url    String?   @db.VarChar(500)
  is_active     Boolean   @default(true)
  is_locked     Boolean   @default(false)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  passwordResetTokens PasswordResetToken[]
  customerAddresses   CustomerAddress[]
  technicianProfile   TechnicianProfile?
  voucherUsages       VoucherUsage[]
  bookings            Booking[]
  statusHistories     BookingStatusHistory[]
  createdQuotations   Quotation[]            @relation("CreatedQuotations")
  respondedQuotations Quotation[]            @relation("RespondedQuotations")
  confirmedPayments   Payment[]              @relation("ConfirmedPayments")
  settledPayments     Payment[]              @relation("SettledPayments")
  reviews             Review[]
  complaints          Complaint[]
  notifications       Notification[]

  @@map("users")
}

model PasswordResetToken {
  id         Int       @id @default(autoincrement())
  user_id    Int
  otp_code   String    @db.VarChar(6)
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

enum DistrictType {
  CENTER
  SUBURB
}

model District {
  id         Int          @id @default(autoincrement())
  name       String       @db.VarChar(100)
  type       DistrictType
  is_active  Boolean      @default(true)
  created_at DateTime     @default(now())
  updated_at DateTime     @updatedAt

  wards               Ward[]
  customerAddresses   CustomerAddress[]
  technicianProfiles  TechnicianProfile[]
  bookings            Booking[]

  @@map("districts")
}

enum WardType {
  PHUONG
  XA
  THI_TRAN
}

model Ward {
  id          Int      @id @default(autoincrement())
  district_id Int
  name        String   @db.VarChar(100)
  type        WardType
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  district          District          @relation(fields: [district_id], references: [id], onDelete: Cascade)
  customerAddresses CustomerAddress[]
  bookings          Booking[]

  @@map("wards")
}

model CustomerAddress {
  id             Int      @id @default(autoincrement())
  customer_id    Int
  district_id    Int
  ward_id        Int
  address_detail String   @db.VarChar(500)
  label          String   @default("Nhà") @db.VarChar(50)
  is_default     Boolean  @default(false)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  user     User      @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  district District  @relation(fields: [district_id], references: [id], onDelete: Cascade)
  ward     Ward      @relation(fields: [ward_id], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@map("customer_addresses")
}

model ServiceCategory {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  description String?  @db.Text
  icon_url    String?  @db.VarChar(500)
  is_active   Boolean  @default(true)
  is_deleted  Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  services    Service[]
  deviceTypes DeviceType[]

  @@map("service_categories")
}

model Service {
  id                 Int      @id @default(autoincrement())
  category_id        Int
  name               String   @db.VarChar(200)
  description        String?  @db.Text
  base_price         Decimal  @db.Decimal(12, 0)
  estimated_duration Int
  image_url          String?  @db.VarChar(500)
  is_active          Boolean  @default(true)
  is_deleted         Boolean  @default(false)
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  category         ServiceCategory   @relation(fields: [category_id], references: [id], onDelete: Cascade)
  technicianSkills TechnicianSkill[]
  bookings         Booking[]

  @@map("services")
}

model DeviceType {
  id          Int      @id @default(autoincrement())
  category_id Int?
  name        String   @db.VarChar(100)
  description String?  @db.Text
  is_active   Boolean  @default(true)
  is_deleted  Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  category ServiceCategory? @relation(fields: [category_id], references: [id], onDelete: SetNull)
  bookings Booking[]

  @@map("device_types")
}

model TechnicianProfile {
  id                   Int      @id @default(autoincrement())
  user_id              Int      @unique
  district_id          Int?
  years_of_experience  Int      @default(0)
  bio                  String?  @db.Text
  avg_rating           Decimal  @default(0.0) @db.Decimal(2, 1)
  total_completed_jobs Int      @default(0)
  is_available         Boolean  @default(true)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  user        User                 @relation(fields: [user_id], references: [id], onDelete: Cascade)
  district    District?            @relation(fields: [district_id], references: [id], onDelete: SetNull)
  skills      TechnicianSkill[]
  schedules   TechnicianSchedule[]
  bookings    Booking[]
  reviews     Review[]

  @@map("technician_profiles")
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  EXPERT
}

model TechnicianSkill {
  id                    Int        @id @default(autoincrement())
  technician_profile_id Int
  service_id            Int
  skill_level           SkillLevel
  created_at            DateTime   @default(now())

  profile TechnicianProfile @relation(fields: [technician_profile_id], references: [id], onDelete: Cascade)
  service Service           @relation(fields: [service_id], references: [id], onDelete: Cascade)

  @@unique([technician_profile_id, service_id])
  @@map("technician_skills")
}

model TechnicianSchedule {
  id                    Int      @id @default(autoincrement())
  technician_profile_id Int
  day_of_week           Int
  start_time            String   @db.VarChar(5) // Store as 'HH:mm'
  end_time              String   @db.VarChar(5)
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  profile TechnicianProfile @relation(fields: [technician_profile_id], references: [id], onDelete: Cascade)

  @@map("technician_schedules")
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

model Voucher {
  id               Int          @id @default(autoincrement())
  code             String       @unique @db.VarChar(50)
  discount_type    DiscountType
  discount_value   Decimal      @db.Decimal(12, 0)
  min_order_amount Decimal      @default(0) @db.Decimal(12, 0)
  max_discount     Decimal?     @db.Decimal(12, 0)
  usage_limit      Int
  used_count       Int          @default(0)
  start_date       DateTime     @db.Date
  end_date         DateTime     @db.Date
  is_active        Boolean      @default(true)
  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt

  usages   VoucherUsage[]
  bookings Booking[]

  @@map("vouchers")
}

model VoucherUsage {
  id         Int      @id @default(autoincrement())
  voucher_id Int
  user_id    Int
  booking_id Int
  used_at    DateTime @default(now())

  voucher Voucher @relation(fields: [voucher_id], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  booking Booking @relation(fields: [booking_id], references: [id], onDelete: Cascade)

  @@unique([voucher_id, booking_id])
  @@map("voucher_usages")
}

enum PaymentMethod {
  VNPAY
  CASH
}

model Booking {
  id                    Int           @id @default(autoincrement())
  customer_id           Int
  technician_profile_id Int?
  service_id            Int
  device_type_id        Int?
  description           String        @db.Text
  customer_address_id   Int?
  district_id           Int
  ward_id               Int
  address_detail        String        @db.VarChar(500)
  booking_date          DateTime      @db.Date
  time_slot_start       String        @db.VarChar(5) // HH:mm
  time_slot_end         String        @db.VarChar(5) // HH:mm
  status                String        @default("PENDING") @db.VarChar(30)
  estimated_price       Decimal       @db.Decimal(12, 0)
  final_price           Decimal?      @db.Decimal(12, 0)
  payment_method        PaymentMethod
  voucher_id            Int?
  discount_amount       Decimal       @default(0) @db.Decimal(12, 0)
  inspection_note       String?       @db.Text
  ai_severity           String?       @db.VarChar(20)
  ai_summary            String?       @db.Text
  created_at            DateTime      @default(now())
  updated_at            DateTime      @updatedAt

  customer          User                  @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  technicianProfile TechnicianProfile?    @relation(fields: [technician_profile_id], references: [id], onDelete: SetNull)
  service           Service               @relation(fields: [service_id], references: [id], onDelete: Cascade)
  deviceType        DeviceType?           @relation(fields: [device_type_id], references: [id], onDelete: SetNull)
  customerAddress   CustomerAddress?      @relation(fields: [customer_address_id], references: [id], onDelete: SetNull)
  district          District              @relation(fields: [district_id], references: [id])
  ward              Ward                  @relation(fields: [ward_id], references: [id])
  voucher           Voucher?              @relation(fields: [voucher_id], references: [id], onDelete: SetNull)
  
  images          BookingImage[]
  statusHistories BookingStatusHistory[]
  quotations      Quotation[]
  payment         Payment?
  review          Review?
  complaints      Complaint[]
  aiAnalyses      AiAnalysis[]
  voucherUsages   VoucherUsage[]

  @@map("bookings")
}

enum UploaderType {
  CUSTOMER
  TECHNICIAN
}

model BookingImage {
  id          Int          @id @default(autoincrement())
  booking_id  Int
  image_url   String       @db.VarChar(500)
  uploaded_by UploaderType
  uploaded_at DateTime     @default(now())

  booking Booking @relation(fields: [booking_id], references: [id], onDelete: Cascade)

  @@map("booking_images")
}

model BookingStatusHistory {
  id          Int      @id @default(autoincrement())
  booking_id  Int
  from_status String?  @db.VarChar(30)
  to_status   String   @db.VarChar(30)
  changed_by  Int
  note        String?  @db.Text
  created_at  DateTime @default(now())

  booking Booking @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [changed_by], references: [id], onDelete: Cascade)

  @@map("booking_status_history")
}

enum QuotationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Quotation {
  id                Int             @id @default(autoincrement())
  booking_id        Int
  total_extra_price Decimal         @db.Decimal(12, 0)
  note              String?         @db.Text
  status            QuotationStatus @default(PENDING)
  created_by        Int
  responded_by      Int?
  responded_at      DateTime?
  created_at        DateTime        @default(now())
  updated_at        DateTime        @updatedAt

  booking   Booking         @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  creator   User            @relation("CreatedQuotations", fields: [created_by], references: [id], onDelete: Cascade)
  responder User?           @relation("RespondedQuotations", fields: [responded_by], references: [id], onDelete: SetNull)
  items     QuotationItem[]

  @@map("quotations")
}

model QuotationItem {
  id           Int      @id @default(autoincrement())
  quotation_id Int
  item_name    String   @db.VarChar(200)
  quantity     Int      @default(1)
  unit_price   Decimal  @db.Decimal(12, 0)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  quotation Quotation @relation(fields: [quotation_id], references: [id], onDelete: Cascade)

  @@map("quotation_items")
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  FAILED
}

enum PaymentSettlementStatus {
  NOT_REQUIRED
  PENDING
  SETTLED
}

model Payment {
  id                  Int                     @id @default(autoincrement())
  booking_id          Int                     @unique
  amount              Decimal                 @db.Decimal(12, 0)
  method              PaymentMethod
  status              PaymentStatus           @default(UNPAID)
  settlement_status   PaymentSettlementStatus @default(NOT_REQUIRED)
  transaction_code    String?                 @db.VarChar(100)
  vnpay_txn_ref       String?                 @db.VarChar(100)
  vnpay_response_code String?                 @db.VarChar(10)
  payment_url         String?                 @db.Text
  failed_reason       String?                 @db.VarChar(255)
  paid_at             DateTime?
  confirmed_by        Int?
  settled_at          DateTime?
  settled_by          Int?
  settlement_note     String?                 @db.VarChar(500)
  created_at          DateTime                @default(now())
  updated_at          DateTime                @updatedAt

  booking   Booking @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  confirmer User?   @relation("ConfirmedPayments", fields: [confirmed_by], references: [id], onDelete: SetNull)
  settler   User?   @relation("SettledPayments", fields: [settled_by], references: [id], onDelete: SetNull)

  @@index([method, status, settlement_status])
  @@map("payments")
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

model Review {
  id                    Int        @id @default(autoincrement())
  booking_id            Int        @unique
  customer_id           Int
  technician_profile_id Int
  rating                Int
  comment               String?    @db.Text
  ai_sentiment          Sentiment?
  created_at            DateTime   @default(now())

  booking           Booking           @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  customer          User              @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  technicianProfile TechnicianProfile @relation(fields: [technician_profile_id], references: [id], onDelete: Cascade)

  @@map("reviews")
}

enum ComplaintStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  REJECTED
}

model Complaint {
  id             Int             @id @default(autoincrement())
  booking_id     Int
  customer_id    Int
  subject        String          @db.VarChar(200)
  description    String          @db.Text
  status         ComplaintStatus @default(OPEN)
  admin_response String?         @db.Text
  ai_sentiment   Sentiment?
  resolved_at    DateTime?
  created_at     DateTime        @default(now())
  updated_at     DateTime        @updatedAt

  booking  Booking @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  customer User    @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  @@map("complaints")
}

model Notification {
  id           Int      @id @default(autoincrement())
  user_id      Int
  title        String   @db.VarChar(200)
  message      String   @db.Text
  type         String   @db.VarChar(50)
  reference_id Int?
  is_read      Boolean  @default(false)
  created_at   DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model AiAnalysis {
  id                 Int      @id @default(autoincrement())
  booking_id         Int
  input_text         String   @db.Text
  suggested_services Json?
  severity           String?  @db.VarChar(20)
  tech_summary       String?  @db.Text
  raw_response       Json?
  created_at         DateTime @default(now())

  booking Booking @relation(fields: [booking_id], references: [id], onDelete: Cascade)

  @@map("ai_analysis")
}

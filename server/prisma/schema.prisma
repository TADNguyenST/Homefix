generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  Int                    @id @default(autoincrement())
  email               String                 @unique @db.VarChar(255)
  password_hash       String                 @db.VarChar(255)
  role                Role
  full_name           String                 @db.VarChar(100)
  phone               String?                @db.VarChar(15)
  avatar_url          String?                @db.VarChar(500)
  is_active           Boolean                @default(true)
  created_at          DateTime               @default(now())
  updated_at          DateTime               @updatedAt
  is_locked           Boolean                @default(false)
  blogs               Blog[]
  statusHistories     BookingStatusHistory[]
  bookings            Booking[]
  complaints          Complaint[]
  customerAddresses   CustomerAddress[]
  notifications       Notification[]
  passwordResetTokens PasswordResetToken[]
  confirmedPayments   Payment[]              @relation("ConfirmedPayments")
  settledPayments     Payment[]              @relation("SettledPayments")
  createdQuotations   Quotation[]            @relation("CreatedQuotations")
  respondedQuotations Quotation[]            @relation("RespondedQuotations")
  reviews             Review[]
  technicianProfile   TechnicianProfile?
  voucherUsages       VoucherUsage[]

  @@map("users")
}

model PasswordResetToken {
  id         Int       @id @default(autoincrement())
  user_id    Int
  otp_code   String    @db.VarChar(6)
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model District {
  id                 Int                 @id @default(autoincrement())
  name               String              @unique @db.VarChar(100)
  created_at         DateTime            @default(now())
  updated_at         DateTime            @updatedAt
  is_active          Boolean             @default(true)
  province_code      Int?
  province_name      String?             @db.VarChar(100)
  bookings           Booking[]
  customerAddresses  CustomerAddress[]
  technicianProfiles TechnicianProfile[]
  wards              Ward[]

  @@index([province_code, is_active])
  @@map("districts")
}

model Ward {
  id                Int               @id @default(autoincrement())
  district_id       Int
  name              String            @db.VarChar(100)
  type              WardType
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt
  external_code     Int?              @unique
  is_active         Boolean           @default(true)
  bookings          Booking[]
  customerAddresses CustomerAddress[]
  district          District          @relation(fields: [district_id], references: [id], onDelete: Cascade)

  @@unique([district_id, name])
  @@index([district_id, is_active])
  @@map("wards")
}

model CustomerAddress {
  id             Int       @id @default(autoincrement())
  customer_id    Int
  district_id    Int
  ward_id        Int
  address_detail String    @db.VarChar(500)
  label          String    @default("Nhà") @db.VarChar(50)
  is_default     Boolean   @default(false)
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt
  bookings       Booking[]
  user           User      @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  district       District  @relation(fields: [district_id], references: [id], onDelete: Cascade)
  ward           Ward      @relation(fields: [ward_id], references: [id], onDelete: Cascade)

  @@map("customer_addresses")
}

model ServiceCategory {
  id          Int          @id @default(autoincrement())
  name        String       @db.VarChar(100)
  description String?
  icon_url    String?      @db.VarChar(500)
  is_active   Boolean      @default(true)
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt
  is_deleted  Boolean      @default(false)
  deviceTypes DeviceType[]
  services    Service[]

  @@map("service_categories")
}

model Service {
  id                 Int               @id @default(autoincrement())
  category_id        Int
  name               String            @db.VarChar(200)
  description        String?
  base_price         Decimal           @db.Decimal(12, 0)
  estimated_duration Int
  image_url          String?           @db.VarChar(500)
  is_active          Boolean           @default(true)
  created_at         DateTime          @default(now())
  updated_at         DateTime          @updatedAt
  is_deleted         Boolean           @default(false)
  bookings           Booking[]
  category           ServiceCategory   @relation(fields: [category_id], references: [id], onDelete: Cascade)
  technicianSkills   TechnicianSkill[]

  @@map("services")
}

model DeviceType {
  id          Int              @id @default(autoincrement())
  name        String           @db.VarChar(100)
  description String?
  is_active   Boolean          @default(true)
  created_at  DateTime         @default(now())
  updated_at  DateTime         @updatedAt
  category_id Int?
  is_deleted  Boolean          @default(false)
  bookings    Booking[]
  category    ServiceCategory? @relation(fields: [category_id], references: [id])

  @@map("device_types")
}

model TechnicianProfile {
  id                   Int                  @id @default(autoincrement())
  user_id              Int                  @unique
  district_id          Int?
  years_of_experience  Int                  @default(0)
  bio                  String?
  avg_rating           Decimal              @default(0.0) @db.Decimal(2, 1)
  total_completed_jobs Int                  @default(0)
  is_available         Boolean              @default(true)
  created_at           DateTime             @default(now())
  updated_at           DateTime             @updatedAt
  bookings             Booking[]
  reviews              Review[]
  district             District?            @relation(fields: [district_id], references: [id])
  user                 User                 @relation(fields: [user_id], references: [id], onDelete: Cascade)
  schedules            TechnicianSchedule[]
  skills               TechnicianSkill[]

  @@map("technician_profiles")
}

model TechnicianSkill {
  id                    Int               @id @default(autoincrement())
  technician_profile_id Int
  service_id            Int
  skill_level           SkillLevel
  created_at            DateTime          @default(now())
  service               Service           @relation(fields: [service_id], references: [id], onDelete: Cascade)
  profile               TechnicianProfile @relation(fields: [technician_profile_id], references: [id], onDelete: Cascade)

  @@unique([technician_profile_id, service_id])
  @@map("technician_skills")
}

model TechnicianSchedule {
  id                    Int               @id @default(autoincrement())
  technician_profile_id Int
  day_of_week           Int
  start_time            String            @db.VarChar(5)
  end_time              String            @db.VarChar(5)
  created_at            DateTime          @default(now())
  updated_at            DateTime          @updatedAt
  profile               TechnicianProfile @relation(fields: [technician_profile_id], references: [id], onDelete: Cascade)

  @@map("technician_schedules")
}

model Voucher {
  id               Int            @id @default(autoincrement())
  code             String         @unique @db.VarChar(50)
  discount_type    DiscountType
  discount_value   Decimal        @db.Decimal(12, 0)
  min_order_amount Decimal        @default(0) @db.Decimal(12, 0)
  max_discount     Decimal?       @db.Decimal(12, 0)
  usage_limit      Int
  used_count       Int            @default(0)
  start_date       DateTime       @db.Date
  end_date         DateTime       @db.Date
  is_active        Boolean        @default(true)
  created_at       DateTime       @default(now())
  updated_at       DateTime       @updatedAt
  bookings         Booking[]
  usages           VoucherUsage[]

  @@map("vouchers")
}

model VoucherUsage {
  id         Int      @id @default(autoincrement())
  voucher_id Int
  user_id    Int
  booking_id Int
  used_at    DateTime @default(now())
  booking    Booking  @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  voucher    Voucher  @relation(fields: [voucher_id], references: [id], onDelete: Cascade)

  @@unique([voucher_id, booking_id])
  @@unique([voucher_id, user_id])
  @@map("voucher_usages")
}

model Booking {
  id                    Int                    @id @default(autoincrement())
  customer_id           Int
  technician_profile_id Int?
  service_id            Int
  device_type_id        Int?
  description           String
  customer_address_id   Int?
  district_id           Int
  ward_id               Int
  address_detail        String                 @db.VarChar(500)
  booking_date          DateTime               @db.Date
  time_slot_start       String                 @db.VarChar(5)
  time_slot_end         String                 @db.VarChar(5)
  status                String                 @default("PENDING") @db.VarChar(30)
  estimated_price       Decimal                @db.Decimal(12, 0)
  final_price           Decimal?               @db.Decimal(12, 0)
  payment_method        PaymentMethod
  voucher_id            Int?
  discount_amount       Decimal                @default(0) @db.Decimal(12, 0)
  inspection_note       String?
  ai_severity           String?                @db.VarChar(20)
  ai_summary            String?
  created_at            DateTime               @default(now())
  updated_at            DateTime               @updatedAt
  aiAnalyses            AiAnalysis[]
  images                BookingImage[]
  statusHistories       BookingStatusHistory[]
  customerAddress       CustomerAddress?       @relation(fields: [customer_address_id], references: [id])
  customer              User                   @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  deviceType            DeviceType?            @relation(fields: [device_type_id], references: [id])
  district              District               @relation(fields: [district_id], references: [id])
  service               Service                @relation(fields: [service_id], references: [id], onDelete: Cascade)
  technicianProfile     TechnicianProfile?     @relation(fields: [technician_profile_id], references: [id])
  voucher               Voucher?               @relation(fields: [voucher_id], references: [id])
  ward                  Ward                   @relation(fields: [ward_id], references: [id])
  complaints            Complaint[]
  payment               Payment?
  quotations            Quotation[]
  review                Review?
  voucherUsages         VoucherUsage[]

  @@map("bookings")
}

model BookingImage {
  id          Int          @id @default(autoincrement())
  booking_id  Int
  image_url   String       @db.VarChar(500)
  uploaded_by UploaderType
  uploaded_at DateTime     @default(now())
  booking     Booking      @relation(fields: [booking_id], references: [id], onDelete: Cascade)

  @@map("booking_images")
}

model BookingStatusHistory {
  id          Int      @id @default(autoincrement())
  booking_id  Int
  from_status String?  @db.VarChar(30)
  to_status   String   @db.VarChar(30)
  changed_by  Int
  note        String?
  created_at  DateTime @default(now())
  booking     Booking  @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [changed_by], references: [id], onDelete: Cascade)

  @@map("booking_status_history")
}

model Quotation {
  id                Int             @id @default(autoincrement())
  booking_id        Int
  total_extra_price Decimal         @db.Decimal(12, 0)
  note              String?
  status            QuotationStatus @default(PENDING)
  created_by        Int
  responded_by      Int?
  responded_at      DateTime?
  created_at        DateTime        @default(now())
  updated_at        DateTime        @updatedAt
  items             QuotationItem[]
  booking           Booking         @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  creator           User            @relation("CreatedQuotations", fields: [created_by], references: [id], onDelete: Cascade)
  responder         User?           @relation("RespondedQuotations", fields: [responded_by], references: [id])

  @@map("quotations")
}

model QuotationItem {
  id           Int       @id @default(autoincrement())
  quotation_id Int
  item_name    String    @db.VarChar(200)
  quantity     Int       @default(1)
  unit_price   Decimal   @db.Decimal(12, 0)
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  quotation    Quotation @relation(fields: [quotation_id], references: [id], onDelete: Cascade)

  @@map("quotation_items")
}

model Payment {
  id                  Int                     @id @default(autoincrement())
  booking_id          Int                     @unique
  amount              Decimal                 @db.Decimal(12, 0)
  method              PaymentMethod
  status              PaymentStatus           @default(UNPAID)
  transaction_code    String?                 @db.VarChar(100)
  vnpay_txn_ref       String?                 @db.VarChar(100)
  vnpay_response_code String?                 @db.VarChar(10)
  payment_url         String?
  failed_reason       String?                 @db.VarChar(255)
  paid_at             DateTime?
  confirmed_by        Int?
  created_at          DateTime                @default(now())
  updated_at          DateTime                @updatedAt
  settled_at          DateTime?
  settled_by          Int?
  settlement_note     String?                 @db.VarChar(500)
  settlement_status   PaymentSettlementStatus @default(NOT_REQUIRED)
  booking             Booking                 @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  confirmer           User?                   @relation("ConfirmedPayments", fields: [confirmed_by], references: [id])
  settler             User?                   @relation("SettledPayments", fields: [settled_by], references: [id])

  @@index([method, status, settlement_status])
  @@map("payments")
}

model Review {
  id                    Int               @id @default(autoincrement())
  booking_id            Int               @unique
  customer_id           Int
  technician_profile_id Int
  rating                Int
  comment               String?
  ai_sentiment          Sentiment?
  created_at            DateTime          @default(now())
  booking               Booking           @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  customer              User              @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  technicianProfile     TechnicianProfile @relation(fields: [technician_profile_id], references: [id], onDelete: Cascade)

  @@map("reviews")
}

model Complaint {
  id             Int             @id @default(autoincrement())
  booking_id     Int
  customer_id    Int
  subject        String          @db.VarChar(200)
  description    String
  status         ComplaintStatus @default(OPEN)
  admin_response String?
  ai_sentiment   Sentiment?
  resolved_at    DateTime?
  created_at     DateTime        @default(now())
  updated_at     DateTime        @updatedAt
  booking        Booking         @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  customer       User            @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  @@map("complaints")
}

model Notification {
  id           Int      @id @default(autoincrement())
  user_id      Int
  title        String   @db.VarChar(200)
  message      String
  type         String   @db.VarChar(50)
  reference_id Int?
  is_read      Boolean  @default(false)
  created_at   DateTime @default(now())
  user         User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model AiAnalysis {
  id                 Int      @id @default(autoincrement())
  booking_id         Int
  input_text         String
  suggested_services Json?
  severity           String?  @db.VarChar(20)
  tech_summary       String?
  raw_response       Json?
  created_at         DateTime @default(now())
  booking            Booking  @relation(fields: [booking_id], references: [id], onDelete: Cascade)

  @@map("ai_analysis")
}

model Blog {
  id           Int      @id @default(autoincrement())
  title        String   @db.VarChar(255)
  slug         String   @unique @db.VarChar(255)
  content      String
  author_id    Int
  is_published Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  image_urls   String[] @default([])
  author       User     @relation(fields: [author_id], references: [id], onDelete: Cascade)

  @@map("blogs")
}

enum Role {
  CUSTOMER
  TECHNICIAN
  ADMIN
}

enum WardType {
  PHUONG
  XA
  THI_TRAN
  DAC_KHU
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  EXPERT
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum PaymentMethod {
  VNPAY
  CASH
}

enum UploaderType {
  CUSTOMER
  TECHNICIAN
}

enum QuotationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  FAILED
}

enum PaymentSettlementStatus {
  NOT_REQUIRED
  PENDING
  SETTLED
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum ComplaintStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  REJECTED
}
